{
  "name": "oc-blackbytes",
  "version": "0.8.1",
  "description": "An OpenCode plugin tailored to streamline my everyday workflow.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --target bun --format esm --outfile ./dist/index.js",
    "test": "bun test test/*.test.ts test/**/*.test.ts --path-ignore-patterns 'test/e2e/**'",
    "test:unit": "bun test test/*.test.ts test/**/*.test.ts --path-ignore-patterns 'test/e2e/**' --coverage",
    "test:e2e": "BYTES_TEST_DETERMINISTIC=1 bun test test/e2e/",
    "lint": "biome lint src test",
    "format": "biome format --write src test",
    "check": "biome check src test && bun run test:unit && bun run test:e2e",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cuongntr/oc-blackbytes"
  },
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.7",
    "@opencode-ai/sdk": "^1.4.7",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "bun-types": "^1.2.0"
  }
}
